APP_ENV=development
DATABASE_URL=sqlite:///./phase6_analyses.db
EMBEDDING_DIMENSIONS=128
CORS_ORIGINS=*

# Phase 6 AI integration.
# Bring your own key (BYOK): use Gemini or OpenAI.
# OpenAI API keys require billing to be enabled / a paid tier.
ENABLE_OPENAI=true
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
